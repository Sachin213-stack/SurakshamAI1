# ═══════════════════════════════════════════════════════════════════════════════
# SENTINEL-AGENT — Environment Variables
# Copy this file to .env and fill in your keys.
# ═══════════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production        # production | development
DEBUG=false

# ── Security (App-level API Keys) ─────────────────────────────────────────────
# These are keys YOU create to protect your own API endpoints.
# Generate strong random keys at: https://generate-secret.vercel.app/32
# Add multiple keys as comma-separated values: key1,key2,key3
API_KEYS=your-secret-key-1,your-secret-key-2

# ── Groq (LLM Inference) ──────────────────────────────────────────────────────
# Signup  : https://console.groq.com/
# API Keys: https://console.groq.com/keys
# Free tier available. Supports Llama 3, Mixtral, Gemma.
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama3-8b-8192
GROQ_TIMEOUT=10
GROQ_MAX_RETRIES=3

# ── Pinecone (Vector Database / Memory) ───────────────────────────────────────
# Signup  : https://app.pinecone.io/
# API Keys: https://app.pinecone.io/ → API Keys → Create API Key
# Free tier: 1 index, 100k vectors.
PINECONE_API_KEY=pcsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PINECONE_INDEX=sentinel-patterns
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=60        # max requests per window
RATE_LIMIT_WINDOW=60          # window size in seconds

# ── Fraud Thresholds ──────────────────────────────────────────────────────────
OVERLAY_THRESHOLD=50          # score >= this → OVERLAY_WARNING
BLOCK_THRESHOLD=80            # score >= this → BLOCK_CALL

# ── WebSocket ─────────────────────────────────────────────────────────────────
WS_PING_INTERVAL=30           # keepalive ping every N seconds
WS_MAX_CONNECTIONS=100        # max simultaneous WebSocket clients
